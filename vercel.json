{
  "crons": [
    {
      "path": "/api/cron-newsletter-prepare",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron-newsletter",
      "schedule": "0 23 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/ifalgo/:path*",
      "destination": "https://api.ifalgo.com.tw/frontapi/:path*"
    },
    {
      "source": "/api/twse/:path*",
      "destination": "https://openapi.twse.com.tw/v1/:path*"
    },
    {
      "source": "/api/twse-report/:path*",
      "destination": "https://www.twse.com.tw/exchangeReport/:path*"
    },
    {
      "source": "/api/tpex/:path*",
      "destination": "https://www.tpex.org.tw/openapi/v1/:path*"
    },
    {
      "source": "/api/mis/:path*",
      "destination": "https://mis.twse.com.tw/stock/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
